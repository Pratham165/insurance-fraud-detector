# ─── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ─── Virtual Environment ─────────────────────
venv/
.venv/
env/

# ─── Environment Variables ───────────────────
.env
