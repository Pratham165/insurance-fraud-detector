# ─── Model Artifacts ─────────────────────────────
# Allow inference artifacts needed by the backend server
!models/pipeline.pkl
!models/train_medians.pkl
!models/train_modes.pkl
!models/metadata.json
# Block large/optional files not needed for inference
models/feature_importance.csv


# ─── Data Files (too large for git) ──────────
ml/data/raw/*.csv
ml/data/processed/*.csv
*.csv

# ─── Jupyter Notebooks Checkpoints ───────────
.ipynb_checkpoints/

# ─── Node.js / Next.js ──────────────────────
node_modules/
.next/
out/

